# Vina Docking Pipeline Configuration
# Copy to config.env and edit paths for your system.

# --- Required paths ---
# Directory containing complex subdirectories (each with protein.pdb + ligand.sdf)
VINADOCK_COMPLEXES_DIR=/path/to/complexes

# Output directory for results
VINADOCK_OUTPUT_DIR=output

# ADFRsuite Python interpreter (Python 3.7 environment)
VINADOCK_ADFR_PYTHON=/path/to/adcpsuite/bin/python

# ADFRsuite prepare_receptor4.py script
VINADOCK_ADFR_PREP_RECEPTOR=/path/to/adcpsuite/lib/python3.7/site-packages/AutoDockTools/Utilities24/prepare_receptor4.py

# --- Docking parameters ---
VINADOCK_EXHAUSTIVENESS=8
VINADOCK_NUM_MODES=10
VINADOCK_NUM_RUNS=10
VINADOCK_ENERGY_RANGE=5.0
VINADOCK_VINA_TIMEOUT=600

# --- Grid box ---
# Padding (angstroms) added to each side of ligand bounding box
VINADOCK_GRID_PADDING=3.0
# Maximum grid dimension (Vina limit)
VINADOCK_MAX_GRID_SIZE=126.0

# --- Production ---
# Skip complexes that already have scores.csv
VINADOCK_SKIP_EXISTING=true
# Failure log filename (relative to output dir)
VINADOCK_FAIL_LOG=failures.csv
