Bootstrap: docker
From: continuumio/miniconda3:24.1.2-0

%labels
    Author ymnoh
    Description Vina docking pipeline container for Nurion

%environment
    export LC_ALL=C
    export LANG=C
    export PATH=/opt/conda/envs/vina_dock/bin:/opt/ADFRsuite/bin:/opt/conda/bin:$PATH
    export LD_LIBRARY_PATH=/opt/ADFRsuite/lib:${LD_LIBRARY_PATH}

%post
    apt-get update
    apt-get install -y --no-install-recommends \
        bash \
        ca-certificates \
        git \
        wget \
        bzip2 \
        build-essential
    rm -rf /var/lib/apt/lists/*

    /opt/conda/bin/conda create -n vina_dock -y python=3.10
    /opt/conda/bin/conda install -n vina_dock -y -c conda-forge \
        numpy rdkit spyrmsd vina meeko

    cd /tmp && \
        wget -q https://ccsb.scripps.edu/adfr/download/1038/ -O ADFRsuite_x86_64Linux_1.0.tar.gz && \
        tar xzf ADFRsuite_x86_64Linux_1.0.tar.gz && \
        cd ADFRsuite_x86_64Linux_1.0 && \
        ./install.sh -d /opt/ADFRsuite -c 0 && \
        rm -rf /tmp/ADFRsuite*

    /opt/conda/bin/conda clean -afy

%runscript
    exec "$@"
